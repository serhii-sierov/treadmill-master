{
  "expo": {
    "name": "treadmill-master",
    "slug": "treadmill-master",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "treadmillmaster",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Connect to your treadmill via Bluetooth to control speed and incline.",
        "NSHealthShareUsageDescription": "Read workout data to display statistics.",
        "NSHealthUpdateUsageDescription": "Save completed treadmill workouts to Apple Health."
      },
      "bundleIdentifier": "com.anonymous.treadmillmaster"
    },
    "android": {
      "permissions": [
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E85D2C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.treadmillmaster"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F8FAFC"
        }
      ],
      "expo-sqlite",
      [
        "react-native-ble-plx",
        {
          "bluetoothAlwaysPermission": "Connect to your treadmill to control speed and incline during workouts."
        }
      ],
      "./plugins/withDevLauncherBuildPhaseFix.js"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
